@if (Show)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog"
         style="background:rgba(0,0,0,.5);">
        <div class="modal-dialog modal-dialog-centered" style="max-width:460px" @onclick:stopPropagation>
            <div class="modal-content border-0 shadow-lg" style="border-radius:14px;overflow:hidden">

                <!-- Branded header -->
                <div class="d-flex align-items-center gap-2 px-4 py-3"
                     style="background:linear-gradient(135deg,#0d6efd 0%,#0a58ca 100%)">
                    <img src="data:image/png;base64,"
                         width="28" height="28" alt="GoCheaper" />
                    <span class="fw-bold text-white" style="font-size:1rem;letter-spacing:.4px">GoCheaper</span>
                    <button type="button" class="btn-close btn-close-white ms-auto"
                            @onclick="HandleCancel" aria-label="Close"></button>
                </div>

                <!-- Warning icon + title + body -->
                <div class="px-4 pt-4 pb-2">
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <svg width="38" height="38" viewBox="0 0 38 38" fill="none" xmlns="http://www.w3.org/2000/svg" style="flex-shrink:0">
                            <circle cx="19" cy="19" r="19" fill="#fff3cd"/>
                            <circle cx="19" cy="19" r="14" fill="#ffc107"/>
                            <rect x="17.5" y="11" width="3" height="10" rx="1.5" fill="white"/>
                            <circle cx="19" cy="26" r="1.8" fill="white"/>
                        </svg>
                        <h5 class="fw-bold mb-0" style="color:#1a1a2e;font-size:1.1rem">@Title</h5>
                    </div>
                    @if (ChildContent is not null)
                    {
                        @ChildContent
                    }
                    else if (!string.IsNullOrEmpty(Message))
                    {
                        <p class="text-muted mb-0" style="font-size:.92rem;line-height:1.5">@Message</p>
                    }
                </div>

                <!-- Buttons -->
                <div class="px-4 pb-4 pt-3 d-flex justify-content-end gap-2">
                    <button type="button"
                            class="btn btn-danger fw-semibold"
                            style="border-radius:8px;min-width:90px"
                            @onclick="HandleCancel">@CancelLabel</button>
                    <button type="button"
                            class="btn @ConfirmButtonClass fw-semibold"
                            style="border-radius:8px;min-width:90px"
                            disabled="@ConfirmDisabled"
                            @onclick="HandleConfirm">@ConfirmLabel</button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool             Show               { get; set; }
    [Parameter] public string           Title              { get; set; } = "Confirm";
    [Parameter] public string           Message            { get; set; } = "";
    [Parameter] public string           ConfirmLabel       { get; set; } = "OK";
    [Parameter] public string           CancelLabel        { get; set; } = "Cancel";
    [Parameter] public string           ConfirmButtonClass { get; set; } = "btn-success";
    [Parameter] public bool             ConfirmDisabled    { get; set; }
    [Parameter] public EventCallback    OnConfirm          { get; set; }
    [Parameter] public EventCallback    OnCancel           { get; set; }
    [Parameter] public RenderFragment?  ChildContent       { get; set; }

    private async Task HandleConfirm() => await OnConfirm.InvokeAsync();
    private async Task HandleCancel()  => await OnCancel.InvokeAsync();
}
