@if (Show)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog" style="background:rgba(0,0,0,.45);">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content shadow">
                <div class="modal-header border-0 pb-1">
                    <h5 class="modal-title fw-semibold">@Title</h5>
                    <button type="button" class="btn-close" @onclick="HandleCancel" aria-label="Close"></button>
                </div>
                <div class="modal-body pt-1">
                    @if (ChildContent is not null)
                    {
                        @ChildContent
                    }
                    else if (!string.IsNullOrEmpty(Message))
                    {
                        <p class="mb-0 text-muted">@Message</p>
                    }
                </div>
                <div class="modal-footer border-0 pt-1">
                    <button type="button" class="btn btn-outline-secondary" @onclick="HandleCancel">@CancelLabel</button>
                    <button type="button" class="btn @ConfirmButtonClass" @onclick="HandleConfirm" disabled="@ConfirmDisabled">@ConfirmLabel</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool             Show               { get; set; }
    [Parameter] public string           Title              { get; set; } = "Confirm";
    [Parameter] public string           Message            { get; set; } = "";
    [Parameter] public string           ConfirmLabel       { get; set; } = "OK";
    [Parameter] public string           CancelLabel        { get; set; } = "Cancel";
    [Parameter] public string           ConfirmButtonClass { get; set; } = "btn-danger";
    [Parameter] public bool             ConfirmDisabled    { get; set; }
    [Parameter] public EventCallback    OnConfirm          { get; set; }
    [Parameter] public EventCallback    OnCancel           { get; set; }
    [Parameter] public RenderFragment?  ChildContent       { get; set; }

    private async Task HandleConfirm() => await OnConfirm.InvokeAsync();
    private async Task HandleCancel()  => await OnCancel.InvokeAsync();
}
