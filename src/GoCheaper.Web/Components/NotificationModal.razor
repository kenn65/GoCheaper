@if (Show)
{
    <div class="modal fade show d-block" tabindex="-1" role="dialog"
         style="background:rgba(0,0,0,.5);" @onclick="HandleClose">
        <div class="modal-dialog modal-dialog-centered" style="max-width:420px" @onclick:stopPropagation>
            <div class="modal-content border-0 shadow-lg" style="border-radius:14px;overflow:hidden">

                <!-- Branded header -->
                <div class="d-flex align-items-center gap-2 px-4 py-3"
                     style="background:linear-gradient(135deg,#0d6efd 0%,#0a58ca 100%)">
                    <img src="data:image/png;base64,"
                         width="28" height="28" alt="GoCheaper" />
                    <span class="fw-bold text-white" style="font-size:1rem;letter-spacing:.4px">GoCheaper</span>
                    <button type="button" class="btn-close btn-close-white ms-auto"
                            @onclick="HandleClose" aria-label="Close"></button>
                </div>

                <!-- Success icon + title + message -->
                <div class="px-4 pt-4 pb-2 text-center">
                    <div class="mb-3">
                        <svg width="58" height="58" viewBox="0 0 58 58" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <circle cx="29" cy="29" r="29" fill="#d1f0da"/>
                            <circle cx="29" cy="29" r="21" fill="#198754"/>
                            <polyline points="19,29 26,36 39,22"
                                      stroke="white" stroke-width="3.5"
                                      stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </div>
                    <h5 class="fw-bold mb-2" style="color:#1a1a2e;font-size:1.15rem">@Title</h5>
                    <p class="text-muted mb-0 px-2" style="font-size:.92rem;line-height:1.5">@Message</p>
                </div>

                <div class="px-4 pb-4 pt-3 d-flex justify-content-center">
                    <button type="button" class="btn btn-primary px-5 fw-semibold"
                            style="border-radius:8px;letter-spacing:.3px"
                            @onclick="HandleClose">OK</button>
                </div>

            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool          Show    { get; set; }
    [Parameter] public string        Title   { get; set; } = "Done";
    [Parameter] public string        Message { get; set; } = "";
    [Parameter] public EventCallback OnClose { get; set; }

    private async Task HandleClose() => await OnClose.InvokeAsync();
}
