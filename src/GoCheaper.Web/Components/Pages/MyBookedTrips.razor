@page "/my-booked-trips"
@rendermode InteractiveServer
@attribute [Authorize]
@using GoCheaper.Web.Services
@inject TripsApiClient TripsClient

<PageTitle>My Booked Trips - GoCheaper</PageTitle>

<div class="container py-4">
    <h1 class="h3 mb-4">My Booked Trips</h1>

    @if (_loading)
    {
        <p class="text-muted">Loading...</p>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger">@_error</div>
    }
    else if (_trips is { Count: 0 })
    {
        <div class="alert alert-info">
            You have not booked any trips yet.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Driver</th>
                        <th>From</th>
                        <th>To</th>
                        <th>Departure</th>
                        <th>Price (DKK)</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var trip in _trips!)
                    {
                        <tr>
                            <td>@trip.DriverFullName</td>
                            <td>@trip.From</td>
                            <td>@trip.To</td>
                            <td>@(trip.DepartureTime?.ToString("dd MMM yyyy HH:mm") ?? "—")</td>
                            <td>@trip.PricePerSeat.ToString("N2")</td>
                            <td>
                                <a href="/trips/@trip.Id" class="btn btn-sm btn-outline-primary">Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<TripSummaryResponse>? _trips;
    private bool _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var result = await TripsClient.GetMyBookedTripsAsync();
        if (result.Success)
            _trips = result.Trips ?? [];
        else
            _error = result.Error;
        _loading = false;
    }
}
