@page "/my-booked-trips"
@rendermode InteractiveServer
@attribute [Authorize]
@using GoCheaper.Web.Services
@inject BookingApiClient BookingClient

<PageTitle>My Booked Trips - GoCheaper</PageTitle>

<div class="container py-4">
    <h1 class="h3 mb-4">My Booked Trips</h1>

    @if (_loading)
    {
        <div class="spinner-border text-primary" role="status"></div>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger">@_error</div>
    }
    else if (_bookings is { Count: 0 })
    {
        <div class="alert alert-info">
            You have not booked any trips yet. <a href="/browse-trips">Browse available trips</a>.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Driver</th>
                        <th>From</th>
                        <th>To</th>
                        <th>Departure</th>
                        <th>Price (DKK)</th>
                        <th>Seats</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var b in _bookings!)
                    {
                        <tr>
                            <td><a href="/driver/@b.DriverId">@b.DriverFullName</a></td>
                            <td>@b.From</td>
                            <td>@b.To</td>
                            <td>@(b.DepartureTime?.ToString("dd MMM yyyy HH:mm") ?? "—")</td>
                            <td>@b.PricePerSeat.ToString("N2")</td>
                            <td>@b.SeatsCount</td>
                            <td>
                                <a href="/passenger/trips/@b.TripId" class="btn btn-sm btn-outline-primary">Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@code {
    private List<PassengerBookingResponse>? _bookings;
    private bool    _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var result = await BookingClient.GetMyBookingsAsync();
        if (result.Success)
            _bookings = result.Bookings ?? [];
        else
            _error = result.Error;
        _loading = false;
    }
}
