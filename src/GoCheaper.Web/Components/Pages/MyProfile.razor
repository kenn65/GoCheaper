@page "/my-profile"
@rendermode @(new InteractiveServerRenderMode(prerender: false))
@attribute [Authorize]
@using GoCheaper.Web.Models
@using GoCheaper.Web.Services
@inject IdentityApiClient IdentityApi
@inject AuthCookieService AuthCookies
@inject UserSession UserSession
@inject NavigationManager Nav

<PageTitle>My Profile - GoCheaper</PageTitle>

<div class="container py-3 py-md-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-7">

            @if (isLoading)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                </div>
            }
            else if (apiError is not null)
            {
                <div class="alert alert-danger">@apiError</div>
            }
            else if (user is not null)
            {
                @if (saveError is not null)
                {
                    <div class="alert alert-danger alert-dismissible">
                        @saveError
                        <button type="button" class="btn-close" @onclick="() => saveError = null"></button>
                    </div>
                }

                <div class="card shadow-sm mb-4">
                    <div class="card-header bg-primary text-white py-3">
                        <h4 class="mb-0">My Profile</h4>
                    </div>
                    <div class="card-body p-4">

                                                <div class="d-flex gap-3 align-items-center mb-4">
                            <div class="flex-shrink-0">
                                @if (!string.IsNullOrEmpty(user.DriverPictureBase64))
                                {
                                    <img src="@ImageDataUrl(user.DriverPictureBase64)"
                                         class="rounded-circle border"
                                         style="width:80px;height:80px;object-fit:cover;"
                                         alt="Profile picture" />
                                }
                                else
                                {
                                    <div class="rounded-circle border bg-secondary d-flex align-items-center
                                                justify-content-center text-white fw-bold fs-2"
                                         style="width:80px;height:80px;">
                                        @user.FirstName[0]
                                    </div>
                                }
                            </div>
                            <div style="min-width:0;overflow:hidden" class="flex-grow-1">
                                <h5 class="mb-1 fw-semibold text-truncate">@user.FirstName @user.LastName</h5>
                                <div class="mb-1">
                                    <span class="text-muted small d-block" style="word-break:break-all;overflow-wrap:break-word">@user.Email</span>
                                    @if (user.IsEmailVerified)
                                    {
                                        <span class="badge bg-success mt-1">Verified</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark mt-1">Unverified</span>
                                    }
                                </div>
                                <div class="text-muted small text-truncate">Member since @user.CreatedAt.ToString("d MMMM yyyy")</div>
                            </div>
                        </div>

                                                <h6 class="text-muted text-uppercase small fw-semibold mb-2">Account Information</h6>
                        <div class="mb-4">
                            <div class="mb-2">
                                <div class="small text-muted">Mobile Phone</div>
                                <div>@(string.IsNullOrEmpty(user.MobilePhone) ? "—" : user.MobilePhone)</div>
                            </div>
                            <div class="mb-2">
                                <div class="small text-muted">Account Type</div>
                                <div>
                                    @if (user.IsDriver && user.IsPassenger)   { <span>Driver &amp; Passenger</span> }
                                    else if (user.IsDriver)                    { <span>Driver</span> }
                                    else if (user.IsPassenger)                 { <span>Passenger</span> }
                                </div>
                            </div>
                        </div>

                        <hr />

                                                <h6 class="text-muted text-uppercase small fw-semibold mb-3">Edit Profile</h6>

                        <div class="mb-3">
                            <label class="form-label">Mobile Phone</label>
                            <input @bind="model.MobilePhone" class="form-control"
                                   placeholder="+45 12 34 56 78" type="tel" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label d-block">Account Type</label>
                            <div class="d-flex flex-column flex-sm-row gap-2 gap-sm-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="chkDriver"
                                           checked="@model.IsDriver"
                                           @onchange="e => model.IsDriver = (bool)e.Value!" />
                                    <label class="form-check-label" for="chkDriver">
                                        <strong>Driver</strong> — I want to offer rides
                                    </label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="chkPassenger"
                                           checked="@model.IsPassenger"
                                           @onchange="e => model.IsPassenger = (bool)e.Value!" />
                                    <label class="form-check-label" for="chkPassenger">
                                        <strong>Passenger</strong> — I want to book rides
                                    </label>
                                </div>
                            </div>
                            @if (roleError is not null)
                            {
                                <div class="text-danger small mt-1">@roleError</div>
                            }
                        </div>

                        @if (model.IsDriver == true)
                        {
                            <div class="mb-4">
                                <label class="form-label">Profile Picture</label>

                                @{
                                    // Show preview of newly selected image, or the saved one
                                    var previewBase64 = model.DriverPictureBase64 ?? user.DriverPictureBase64;
                                }
                                @if (!string.IsNullOrEmpty(previewBase64))
                                {
                                    <div class="mb-2">
                                        <img src="@ImageDataUrl(previewBase64)"
                                             class="rounded border"
                                             style="max-height:140px;max-width:100%;object-fit:contain;"
                                             alt="Profile picture" />
                                    </div>
                                }

                                <InputFile OnChange="HandleImageUpload" accept="image/*" class="form-control" />
                                @if (!string.IsNullOrEmpty(pictureFileName))
                                {
                                    <div class="text-success small mt-1">&#10003; @pictureFileName selected</div>
                                }
                                @if (pictureError is not null)
                                {
                                    <div class="text-danger small mt-1">@pictureError</div>
                                }
                                <div class="form-text">JPEG or PNG, max 5 MB. Leave blank to keep current picture.</div>
                            </div>
                        }

                        <button class="btn btn-primary" @onclick="HandleSave" disabled="@isSaving">
                            @if (isSaving)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Saving&hellip;</span>
                            }
                            else
                            {
                                <span>Save Changes</span>
                            }
                        </button>
                    </div>
                </div>

                <!-- Your Data -->
                <div class="card shadow-sm mb-4">
                    <div class="card-header py-3">
                        <h4 class="mb-0">Your Data</h4>
                    </div>
                    <div class="card-body">
                        <p class="text-muted mb-3">
                            View or download all personal data GoCheaper holds about you — your profile, trips, and bookings.
                            You can save it as a PDF or download a raw JSON file.
                        </p>
                        <a href="/my-data" class="btn btn-outline-primary btn-sm">View &amp; Export My Data</a>
                    </div>
                </div>

                <!-- Danger Zone -->
                <div class="card border-danger shadow-sm">
                    <div class="card-header bg-danger text-white py-3">
                        <h4 class="mb-0">Danger Zone</h4>
                    </div>
                    <div class="card-body p-4">
                        <p class="text-muted mb-3">
                            Permanently deletes your account and all associated data:
                            your posted trips (passengers will be notified) and all your bookings (drivers will be notified).
                            <strong>This cannot be undone.</strong>
                        </p>

                        <button class="btn btn-outline-danger" @onclick="() => confirmDelete = true">
                            Delete My Account
                        </button>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<NotificationModal Show="saveSuccess"
                   Title="Profile Updated"
                   Message="Your profile changes have been saved."
                   OnClose="() => saveSuccess = false" />

<ConfirmModal Show="confirmDelete"
              Title="Delete Account"
              ConfirmLabel="@(isDeleting ? "Deleting..." : "OK")"
              CancelLabel="Cancel"
              ConfirmDisabled="@(isDeleting || deleteConfirmText != "DELETE")"
              OnConfirm="HandleDeleteAccount"
              OnCancel="CancelDelete">
    <p class="text-muted mb-3">
        This will permanently delete your account and all associated data.
        <strong>This cannot be undone.</strong>
    </p>
    <label class="form-label small fw-semibold">Type DELETE to confirm</label>
    <input class="form-control" @bind="deleteConfirmText" placeholder="DELETE" maxlength="10" />
    @if (deleteError is not null)
    {
        <div class="text-danger small mt-2">@deleteError</div>
    }
</ConfirmModal>

@code {
    private RegisterResponse? user;
    private UpdateProfileModel model = new();
    private bool isLoading = true;
    private bool isSaving;
    private bool saveSuccess;
    private string? apiError;
    private string? saveError;
    private string? roleError;
    private string? pictureError;
    private string pictureFileName = string.Empty;

    // delete account
    private bool    confirmDelete;
    private bool    isDeleting;
    private string  deleteConfirmText = string.Empty;
    private string? deleteError;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        var result = await IdentityApi.GetUserAsync(UserSession.UserId!.Value);
        if (result.Success && result.User is not null)
        {
            user  = result.User;
            model = new UpdateProfileModel
            {
                MobilePhone = user.MobilePhone,
                IsDriver    = user.IsDriver,
                IsPassenger = user.IsPassenger
            };
        }
        else
        {
            apiError = result.Error ?? "Failed to load profile.";
        }

        isLoading = false;
        StateHasChanged();
    }

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        pictureError              = null;
        pictureFileName           = string.Empty;
        model.DriverPictureBase64 = null;

        if (e.File.Size > 5 * 1024 * 1024)
        {
            pictureError = "Image must be smaller than 5 MB.";
            return;
        }

        try
        {
            using var stream = e.File.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms     = new MemoryStream();
            await stream.CopyToAsync(ms);
            model.DriverPictureBase64 = Convert.ToBase64String(ms.ToArray());
            pictureFileName           = e.File.Name;
        }
        catch
        {
            pictureError = "Failed to read the image. Please try a different file.";
        }
    }

    private async Task HandleSave()
    {
        roleError   = null;
        saveError   = null;
        saveSuccess = false;

        if (model.IsDriver == false && model.IsPassenger == false)
        {
            roleError = "At least one of Driver or Passenger must remain selected.";
            return;
        }

        isSaving = true;
        try
        {
            var result = await IdentityApi.UpdateProfileAsync(UserSession.UserId!.Value, model);
            if (result.Success && result.User is not null)
            {
                user            = result.User;
                saveSuccess     = true;
                pictureFileName = string.Empty;
                // Sync updated roles into the auth cookie and live NavMenu
                await AuthCookies.UpdateRolesAsync(result.User.IsDriver, result.User.IsPassenger);
            }
            else
            {
                saveError = result.Error ?? "Update failed. Please try again.";
            }
        }
        finally
        {
            isSaving = false;
        }
    }

    private void CancelDelete()
    {
        confirmDelete     = false;
        deleteConfirmText = string.Empty;
        deleteError       = null;
    }

    private async Task HandleDeleteAccount()
    {
        isDeleting  = true;
        deleteError = null;

        var result = await IdentityApi.DeleteAccountAsync(UserSession.UserId!.Value);
        if (result.Success)
        {
            await AuthCookies.SignOutAsync();
            Nav.NavigateTo("/", forceLoad: true);
        }
        else
        {
            deleteError = result.Error ?? "Could not delete account. Please try again.";
        }

        isDeleting = false;
    }

    // Detects JPEG, PNG or GIF from the base64 binary signature so the data URI renders correctly
    private static string ImageDataUrl(string base64)
    {
        var mime = base64.StartsWith("/9j/")   ? "image/jpeg"
                 : base64.StartsWith("iVBOR")  ? "image/png"
                 : base64.StartsWith("R0lGOD") ? "image/gif"
                 : "image/jpeg";
        return $"data:{mime};base64,{base64}";
    }
}
