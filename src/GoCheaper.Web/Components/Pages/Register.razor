@page "/register"
@rendermode InteractiveServer
@using GoCheaper.Web.Models
@using GoCheaper.Web.Services
@inject IdentityApiClient IdentityApi
@inject IWebHostEnvironment Env

<PageTitle>Register - GoCheaper</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">

            @if (registrationResult is not null)
            {
                <div class="card border-success shadow-sm">
                    <div class="card-body text-center py-5">
                        <div class="mb-3">
                            <span style="font-size: 3rem;">&#10003;</span>
                        </div>
                        <h4 class="text-success">Account Created!</h4>
                        <p class="mb-1">
                            Welcome, <strong>@registrationResult.FirstName @registrationResult.LastName</strong>!
                        </p>
                        <p class="text-muted small mb-3">
                            A verification link will be sent to <strong>@registrationResult.Email</strong>.
                            Please check your inbox to activate your account.
                        </p>
                        @if (Env.IsDevelopment() && registrationResult.EmailVerificationToken is not null)
                        {
                            <div class="alert alert-warning text-start small">
                                <strong>Dev only &mdash; verification token:</strong><br />
                                <code class="user-select-all">@registrationResult.EmailVerificationToken</code>
                            </div>
                        }
                        <a href="/" class="btn btn-primary">Back to Home</a>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white py-3">
                        <h4 class="mb-0">Create your GoCheaper account</h4>
                        <small class="opacity-75">All fields are required</small>
                    </div>
                    <div class="card-body p-4">

                        @if (!string.IsNullOrEmpty(apiError))
                        {
                            <div class="alert alert-danger">@apiError</div>
                        }

                        <EditForm Model="model" OnValidSubmit="HandleSubmit">
                            <DataAnnotationsValidator />

                            <h6 class="text-muted mb-3">Personal Information</h6>

                            <div class="row mb-3">
                                <div class="col-sm-6 mb-3 mb-sm-0">
                                    <label class="form-label">First Name</label>
                                    <InputText @bind-Value="model.FirstName" class="form-control" placeholder="First name" />
                                    <ValidationMessage For="() => model.FirstName" class="text-danger small" />
                                </div>
                                <div class="col-sm-6">
                                    <label class="form-label">Last Name</label>
                                    <InputText @bind-Value="model.LastName" class="form-control" placeholder="Last name" />
                                    <ValidationMessage For="() => model.LastName" class="text-danger small" />
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Email Address</label>
                                <InputText @bind-Value="model.Email" type="email" class="form-control" placeholder="Email address" />
                                <ValidationMessage For="() => model.Email" class="text-danger small" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <InputText @bind-Value="model.Password" class="form-control" type="password"
                                           placeholder="Min. 8 chars · 1 capital · 2 digits" />
                                <ValidationMessage For="() => model.Password" class="text-danger small" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Mobile Phone</label>
                                <InputText @bind-Value="model.MobilePhone" class="form-control" placeholder="Mobile phone" />
                                <ValidationMessage For="() => model.MobilePhone" class="text-danger small" />
                            </div>

                            <hr />
                            <h6 class="text-muted mb-3">Account Type</h6>

                            <div class="mb-3">
                                <div class="d-flex gap-4">
                                    <div class="form-check form-check-inline">
                                        <InputCheckbox @bind-Value="model.IsDriver" class="form-check-input" id="chkDriver" />
                                        <label class="form-check-label" for="chkDriver">
                                            <strong>Driver</strong> &mdash; I want to offer rides
                                        </label>
                                    </div>
                                    <div class="form-check form-check-inline">
                                        <InputCheckbox @bind-Value="model.IsPassenger" class="form-check-input" id="chkPassenger" />
                                        <label class="form-check-label" for="chkPassenger">
                                            <strong>Passenger</strong> &mdash; I want to book rides
                                        </label>
                                    </div>
                                </div>
                                @if (roleError is not null)
                                {
                                    <div class="text-danger small mt-1">@roleError</div>
                                }
                                <div class="form-text">You can select both.</div>
                            </div>

                            <hr />
                            <h6 class="text-muted mb-3">Profile Picture</h6>

                            <div class="mb-4">
                                <InputFile OnChange="HandleImageUpload" accept="image/*" class="form-control" />
                                @if (!string.IsNullOrEmpty(pictureFileName))
                                {
                                    <div class="text-success small mt-1">&#10003; @pictureFileName</div>
                                }
                                @if (pictureError is not null)
                                {
                                    <div class="text-danger small mt-1">@pictureError</div>
                                }
                                <div class="form-text">JPEG or PNG, max 5 MB.</div>
                            </div>

                            <hr />

                            <div class="mb-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="chkPrivacy"
                                           checked="@model.AgreeToPrivacyPolicy"
                                           @onchange="e => model.AgreeToPrivacyPolicy = (bool)e.Value!" />
                                    <label class="form-check-label" for="chkPrivacy">
                                        I have read and agree to the
                                        <a href="/privacy-policy" target="_blank">Privacy Policy</a>
                                    </label>
                                </div>
                                @if (privacyError is not null)
                                {
                                    <div class="text-danger small mt-1">@privacyError</div>
                                }
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100" disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Creating account&hellip;</span>
                                }
                                else
                                {
                                    <span>Create Account</span>
                                }
                            </button>
                        </EditForm>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private readonly RegisterModel model = new();
    private RegisterResponse? registrationResult;
    private string? apiError;
    private string? roleError;
    private string? pictureError;
    private string? privacyError;
    private string pictureFileName = "";
    private bool isLoading;

    private async Task HandleImageUpload(InputFileChangeEventArgs e)
    {
        pictureError = null;
        pictureFileName = "";
        model.DriverPictureBase64 = "";

        var file = e.File;
        if (file.Size > 5 * 1024 * 1024)
        {
            pictureError = "Image must be smaller than 5 MB.";
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var ms = new MemoryStream();
            await stream.CopyToAsync(ms);
            model.DriverPictureBase64 = Convert.ToBase64String(ms.ToArray());
            pictureFileName = file.Name;
        }
        catch
        {
            pictureError = "Failed to read the image. Please try a different file.";
        }
    }

    private async Task HandleSubmit()
    {
        roleError    = null;
        apiError     = null;
        pictureError = null;
        privacyError = null;

        if (!model.IsDriver && !model.IsPassenger)
        {
            roleError = "Please select at least one account type (Driver or Passenger).";
            return;
        }

        if (string.IsNullOrEmpty(model.DriverPictureBase64))
        {
            pictureError = "A profile picture is required.";
            return;
        }

        if (!model.AgreeToPrivacyPolicy)
        {
            privacyError = "You must agree to the Privacy Policy to create an account.";
            return;
        }

        isLoading = true;
        try
        {
            var result = await IdentityApi.RegisterAsync(model);
            if (result.Success)
                registrationResult = result.User;
            else
                apiError = result.Error ?? "Registration failed. Please try again.";
        }
        catch (Exception)
        {
            apiError = "Could not reach the server. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
