@page "/register"
@rendermode InteractiveServer
@using GoCheaper.Web.Models
@using GoCheaper.Web.Services
@inject IdentityApiClient IdentityApi
@inject IWebHostEnvironment Env

<PageTitle>Register - GoCheaper</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">

            @if (registrationResult is not null)
            {
                <div class="card border-success shadow-sm">
                    <div class="card-body text-center py-5">
                        <div class="mb-3">
                            <span style="font-size: 3rem;">&#10003;</span>
                        </div>
                        <h4 class="text-success">Account Created!</h4>
                        <p class="mb-1">
                            Welcome to GoCheaper!
                        </p>
                        <p class="text-muted small mb-3">
                            A verification link will be sent to <strong>@registrationResult.Email</strong>.
                            Please check your inbox to activate your account.
                        </p>
                        @if (Env.IsDevelopment() && registrationResult.EmailVerificationToken is not null)
                        {
                            <div class="alert alert-warning text-start small">
                                <strong>Dev only &mdash; verification token:</strong><br />
                                <code class="user-select-all">@registrationResult.EmailVerificationToken</code>
                            </div>
                        }
                        <a href="/" class="btn btn-primary">Go to Home</a>
                    </div>
                </div>
            }
            else
            {
                <div class="card shadow-sm">
                    <div class="card-header bg-primary text-white py-3">
                        <h4 class="mb-0">Create your GoCheaper account</h4>
                        <small class="opacity-75">You'll complete your profile after signing in</small>
                    </div>
                    <div class="card-body p-4">

                        @if (!string.IsNullOrEmpty(apiError))
                        {
                            <div class="alert alert-danger">@apiError</div>
                        }

                        <EditForm Model="model" OnValidSubmit="HandleSubmit">
                            <DataAnnotationsValidator />

                            <div class="mb-3">
                                <label class="form-label">Email Address</label>
                                <InputText @bind-Value="model.Email" type="email" class="form-control"
                                           placeholder="Email address" autocomplete="email" />
                                <ValidationMessage For="() => model.Email" class="text-danger small" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <InputText @bind-Value="model.Password" class="form-control" type="password"
                                           placeholder="Min. 8 chars · 1 capital · 2 digits" autocomplete="new-password" />
                                <ValidationMessage For="() => model.Password" class="text-danger small" />
                            </div>

                            <div class="mb-4">
                                <label class="form-label">Confirm Password</label>
                                <InputText @bind-Value="model.ConfirmPassword" class="form-control" type="password"
                                           placeholder="Repeat password" autocomplete="new-password" />
                                <ValidationMessage For="() => model.ConfirmPassword" class="text-danger small" />
                            </div>

                            <hr />

                            <div class="mb-4">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="chkPrivacy"
                                           checked="@model.AgreeToPrivacyPolicy"
                                           @onchange="e => model.AgreeToPrivacyPolicy = (bool)e.Value!" />
                                    <label class="form-check-label" for="chkPrivacy">
                                        I have read and agree to the
                                        <a href="/privacy-policy" target="_blank">Privacy Policy</a>
                                    </label>
                                </div>
                                @if (privacyError is not null)
                                {
                                    <div class="text-danger small mt-1">@privacyError</div>
                                }
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100" disabled="@isLoading">
                                @if (isLoading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Creating account&hellip;</span>
                                }
                                else
                                {
                                    <span>Create Account</span>
                                }
                            </button>
                        </EditForm>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    private readonly RegisterModel model = new();
    private RegisterResponse? registrationResult;
    private string? apiError;
    private string? privacyError;
    private bool isLoading;

    private async Task HandleSubmit()
    {
        apiError     = null;
        privacyError = null;

        if (!model.AgreeToPrivacyPolicy)
        {
            privacyError = "You must agree to the Privacy Policy to create an account.";
            return;
        }

        isLoading = true;
        try
        {
            var result = await IdentityApi.RegisterAsync(model);
            if (result.Success)
                registrationResult = result.User;
            else
                apiError = result.Error ?? "Registration failed. Please try again.";
        }
        catch (Exception)
        {
            apiError = "Could not reach the server. Please try again.";
        }
        finally
        {
            isLoading = false;
        }
    }
}
