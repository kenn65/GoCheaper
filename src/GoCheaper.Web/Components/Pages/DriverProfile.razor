@page "/driver/{Id:guid}"
@rendermode InteractiveServer
@attribute [Authorize]
@using GoCheaper.Web.Services
@inject IdentityApiClient IdentityClient
@inject BookingApiClient BookingClient

<PageTitle>Driver Profile - GoCheaper</PageTitle>

<div class="container py-4" style="max-width: 480px;">
    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger">@_error</div>
    }
    else if (_user is not null)
    {
        <div class="card shadow-sm mb-3">
            <div class="card-header bg-primary text-white py-3">
                <h4 class="mb-0">Driver</h4>
            </div>
            <div class="card-body text-center">
                @if (!string.IsNullOrWhiteSpace(_user.DriverPictureBase64))
                {
                    <img src="@ImageDataUrl(_user.DriverPictureBase64)"
                         class="rounded-circle mb-3"
                         style="width:120px;height:120px;object-fit:cover;"
                         alt="Driver photo" />
                }
                else
                {
                    <div class="rounded-circle bg-secondary d-inline-flex align-items-center justify-content-center mb-3"
                         style="width:120px;height:120px;">
                        <span class="text-white fs-1">@(_user.FirstName.FirstOrDefault())</span>
                    </div>
                }
                <h4 class="mb-0">@_user.FirstName @_user.LastName</h4>
                <p class="text-muted small mb-1">Member since @_user.CreatedAt.ToString("MMMM yyyy")</p>
                @if (!string.IsNullOrWhiteSpace(_user.MobilePhone))
                {
                    <p class="mb-0 small">@_user.MobilePhone</p>
                }
            </div>
        </div>

        <!-- Rating summary -->
        <div class="card shadow-sm">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">Driver Rating</h6>

                @if (_ratings is null)
                {
                    <div class="spinner-border spinner-border-sm text-primary" role="status"></div>
                }
                else if (_ratings.RatingCount == 0)
                {
                    <p class="text-muted small mb-0">No ratings yet.</p>
                }
                else
                {
                    <div class="d-flex align-items-center gap-3 mb-3">
                        <span class="fw-bold" style="font-size:2.2rem;color:#ffc107;">@_ratings.AverageRating.ToString("F1")</span>
                        <div>
                            <div>
                                @for (var i = 1; i <= 5; i++)
                                {
                                    <span style="color:@(i <= Math.Round(_ratings.AverageRating) ? "#ffc107" : "#dee2e6");font-size:1.4rem;">&#9733;</span>
                                }
                            </div>
                            <div class="text-muted small">@_ratings.RatingCount rating(s)</div>
                        </div>
                    </div>

                    @if (_ratings.Recent.Count > 0)
                    {
                        <hr class="my-2" />
                        @foreach (var r in _ratings.Recent)
                        {
                            <div class="mb-3">
                                <div>
                                    @for (var i = 1; i <= 5; i++)
                                    {
                                        <span style="color:@(i <= r.Stars ? "#ffc107" : "#dee2e6");font-size:1rem;">&#9733;</span>
                                    }
                                    <span class="text-muted small ms-2">@r.RatedAt.ToString("dd MMM yyyy")</span>
                                </div>
                                @if (!string.IsNullOrWhiteSpace(r.Comment))
                                {
                                    <p class="text-muted small mb-0 mt-1" style="font-style:italic;">&ldquo;@r.Comment&rdquo;</p>
                                }
                            </div>
                        }
                    }
                }
            </div>
        </div>
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private RegisterResponse?   _user;
    private DriverRatingSummary? _ratings;
    private bool    _loading = true;
    private string? _error;

    protected override async Task OnInitializedAsync()
    {
        var userTask    = IdentityClient.GetUserAsync(Id);
        var ratingsTask = BookingClient.GetDriverRatingsAsync(Id);

        await Task.WhenAll(userTask, ratingsTask);

        var userResult    = userTask.Result;
        var ratingsResult = ratingsTask.Result;

        if (userResult.Success)
            _user = userResult.User;
        else
            _error = userResult.Error ?? "Driver not found.";

        if (ratingsResult.Success)
            _ratings = ratingsResult.Summary;

        _loading = false;
    }

    private static string ImageDataUrl(string base64)
    {
        if (base64.StartsWith("data:")) return base64;
        var mime = base64.Length > 4 && base64[..4] == "/9j/" ? "image/jpeg"
                 : base64.Length > 3 && base64[..3] == "iVB" ? "image/png"
                 : "image/jpeg";
        return $"data:{mime};base64,{base64}";
    }
}
