@page "/forgot-password"
@rendermode InteractiveServer
@using GoCheaper.Web.Services
@inject IdentityApiClient IdentityApi
@inject NavigationManager Nav

<PageTitle>Forgot Password - GoCheaper</PageTitle>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white py-3">
                    <h4 class="mb-0">Reset your password</h4>
                </div>
                <div class="card-body p-4">

                    @if (_sent)
                    {
                        <div class="alert alert-success mb-0">
                            If that email address is registered, we have sent a password reset link to your inbox. Please check your email.
                        </div>
                        <div class="mt-3 text-center">
                            <a href="/login" class="btn btn-outline-primary">Back to Sign In</a>
                        </div>
                    }
                    else
                    {
                        <p class="text-muted mb-4">
                            Enter your email address and we will send you a link to reset your password.
                        </p>

                        @if (!string.IsNullOrEmpty(_error))
                        {
                            <div class="alert alert-danger">@_error</div>
                        }

                        <EditForm Model="_model" OnValidSubmit="HandleSubmit">
                            <DataAnnotationsValidator />

                            <div class="mb-4">
                                <label class="form-label">Email Address</label>
                                <InputText @bind-Value="_model.Email" type="email" class="form-control"
                                           placeholder="Email address" autocomplete="email" />
                                <ValidationMessage For="() => _model.Email" class="text-danger small" />
                            </div>

                            <button type="submit" class="btn btn-primary btn-lg w-100" disabled="@_loading">
                                @if (_loading)
                                {
                                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                    <span>Sending&hellip;</span>
                                }
                                else
                                {
                                    <span>Send Reset Link</span>
                                }
                            </button>
                        </EditForm>

                        <hr class="my-4" />
                        <p class="text-center text-muted small mb-0">
                            <a href="/login">Back to Sign In</a>
                        </p>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private readonly ForgotPasswordModel _model = new();
    private string? _error;
    private bool    _loading;
    private bool    _sent;

    private async Task HandleSubmit()
    {
        _error   = null;
        _loading = true;
        try
        {
            var (success, error) = await IdentityApi.ForgotPasswordAsync(_model.Email);
            if (success)
                _sent = true;
            else
                _error = error ?? "Something went wrong. Please try again.";
        }
        catch (Exception)
        {
            _error = "An unexpected error occurred. Please try again.";
        }
        finally
        {
            _loading = false;
        }
    }

    private class ForgotPasswordModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Email is required.")]
        [System.ComponentModel.DataAnnotations.EmailAddress(ErrorMessage = "Enter a valid email address.")]
        public string Email { get; set; } = string.Empty;
    }
}
