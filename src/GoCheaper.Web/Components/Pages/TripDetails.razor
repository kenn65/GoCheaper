@page "/trips/{Id:guid}"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "DriverOnly")]
@using GoCheaper.Web.Services
@using System.ComponentModel.DataAnnotations
@inject TripsApiClient TripsClient
@inject UserSession UserSession

<PageTitle>Trip Details - GoCheaper</PageTitle>

<div class="container py-4" style="max-width:800px">
    @if (_loading)
    {
        <p class="text-muted">Loading...</p>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger">@_error</div>
    }
    else if (_trip is not null)
    {
        var isOwner = UserSession.UserId.HasValue && UserSession.UserId.Value == _trip.DriverId;

        @if (isOwner && _editing)
        {
            <!-- ── Driver: edit form ── -->
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Edit Trip</span>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
                </div>
                <div class="card-body">
                    <EditForm Model="_edit" OnValidSubmit="SaveEditAsync">
                        <DataAnnotationsValidator />

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">From</label>
                                <InputText class="form-control" @bind-Value="_edit.From" />
                                <ValidationMessage For="() => _edit.From" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">To</label>
                                <InputText class="form-control" @bind-Value="_edit.To" />
                                <ValidationMessage For="() => _edit.To" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Total Seats</label>
                                <InputNumber class="form-control" @bind-Value="_edit.TotalSeats" />
                                <ValidationMessage For="() => _edit.TotalSeats" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Price per Seat (DKK)</label>
                                <InputNumber class="form-control" @bind-Value="_edit.PricePerSeat" />
                                <ValidationMessage For="() => _edit.PricePerSeat" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Departure Date &amp; Time</label>
                            <InputDate Type="InputDateType.DateTimeLocal" class="form-control" @bind-Value="_edit.DepartureTime" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Number Plate</label>
                            <InputText class="form-control" @bind-Value="_edit.NumberPlate" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Note</label>
                            <InputTextArea class="form-control" @bind-Value="_edit.Note" rows="3" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Pickup Points</label>
                            @for (var i = 0; i < _editPickupPoints.Count; i++)
                            {
                                var index = i;
                                <div class="input-group mb-2">
                                    <span class="input-group-text">@(index + 1)</span>
                                    <input class="form-control" value="@_editPickupPoints[index]"
                                           @oninput="e => _editPickupPoints[index] = e.Value?.ToString() ?? string.Empty"
                                           placeholder="Address or landmark" />
                                    <button type="button" class="btn btn-outline-danger"
                                            @onclick="() => _editPickupPoints.RemoveAt(index)">✕</button>
                                </div>
                            }
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    @onclick="() => _editPickupPoints.Add(string.Empty)">+ Add Pickup Point</button>
                        </div>

                        @if (_saveError is not null)
                        {
                            <div class="alert alert-danger">@_saveError</div>
                        }

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary" disabled="@_saving">
                                @(_saving ? "Saving..." : "Save Changes")
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }
        else
        {
            <!-- ── Read-only view (driver + passenger) ── -->
            <div class="card shadow-sm">
                <div class="card-body">

                    <div class="d-flex justify-content-between align-items-start mb-3 gap-3">
                        <div>
                            <h2 class="h4 mb-1">@_trip.From → @_trip.To</h2>
                            <p class="text-muted mb-0">Driver: <strong>@_trip.DriverFullName</strong></p>
                        </div>
                        <div class="d-flex flex-column align-items-end gap-2">
                            @if (!string.IsNullOrEmpty(_trip.CarPictureBase64))
                            {
                                <div class="text-end">
                                    <img src="@ImageDataUrl(_trip.CarPictureBase64)"
                                         alt="@(_trip.NumberPlate ?? "Car")"
                                         style="height:80px;object-fit:cover;border-radius:8px;" />
                                    @if (_trip.NumberPlate is not null)
                                    {
                                        <div><small class="text-muted">@_trip.NumberPlate</small></div>
                                    }
                                </div>
                            }
                            @if (isOwner)
                            {
                                <button class="btn btn-sm btn-outline-primary" @onclick="StartEdit">Edit Trip</button>
                            }
                        </div>
                    </div>

                    <dl class="row mb-0">
                        <dt class="col-sm-4">Departure</dt>
                        <dd class="col-sm-8">@(_trip.DepartureTime?.ToString("dd MMM yyyy HH:mm") ?? "—")</dd>

                        <dt class="col-sm-4">Total Seats</dt>
                        <dd class="col-sm-8">@_trip.TotalSeats</dd>

                        <dt class="col-sm-4">Booked Seats</dt>
                        <dd class="col-sm-8">@_trip.BookedSeats</dd>

                        <dt class="col-sm-4">Available Seats</dt>
                        <dd class="col-sm-8">@(_trip.TotalSeats - _trip.BookedSeats)</dd>

                        <dt class="col-sm-4">Price per Seat</dt>
                        <dd class="col-sm-8">@_trip.PricePerSeat.ToString("N2") DKK</dd>

                        @if (!string.IsNullOrWhiteSpace(_trip.Note))
                        {
                            <dt class="col-sm-4">Note</dt>
                            <dd class="col-sm-8">@_trip.Note</dd>
                        }
                    </dl>

                    @if (_trip.PickupPoints is { Count: > 0 })
                    {
                        <h6 class="mt-3 mb-2">Pickup Points</h6>
                        <ol class="mb-0">
                            @foreach (var point in _trip.PickupPoints)
                            {
                                <li>@point</li>
                            }
                        </ol>
                    }


                </div>
            </div>
        }
    }
</div>

@code {
    [Parameter] public Guid Id { get; set; }

    private TripDetailsResponse? _trip;
    private bool _loading = true;
    private string? _error;


    // owner editing
    private bool _editing;
    private bool _saving;
    private string? _saveError;
    private readonly EditModel _edit = new();
    private readonly List<string> _editPickupPoints = [];

    protected override async Task OnInitializedAsync()
    {
        var result = await TripsClient.GetTripDetailsAsync(Id);
        if (result.Success)
            _trip = result.Trip;
        else
            _error = result.Error;
        _loading = false;
    }

    private void StartEdit()
    {
        if (_trip is null) return;
        _edit.From          = _trip.From;
        _edit.To            = _trip.To;
        _edit.TotalSeats    = _trip.TotalSeats;
        _edit.PricePerSeat  = _trip.PricePerSeat;
        _edit.DepartureTime = _trip.DepartureTime ?? default;
        _edit.Note          = _trip.Note;
        _edit.NumberPlate   = _trip.NumberPlate;
        _editPickupPoints.Clear();
        _editPickupPoints.AddRange(_trip.PickupPoints);
        _saveError = null;
        _editing = true;
    }

    private void CancelEdit()
    {
        _editing = false;
        _saveError = null;
    }

    private async Task SaveEditAsync()
    {
        _saving = true;
        _saveError = null;

        var result = await TripsClient.UpdateTripAsync(Id, new
        {
            _edit.From,
            _edit.To,
            _edit.TotalSeats,
            _edit.PricePerSeat,
            DepartureTime = _edit.DepartureTime != default(DateTime) ? (DateTime?)_edit.DepartureTime : null,
            _edit.Note,
            _edit.NumberPlate,
            PickupPoints = _editPickupPoints.Where(p => !string.IsNullOrWhiteSpace(p)).ToList()
        });

        if (result.Success)
        {
            _editing = false;
            var refresh = await TripsClient.GetTripDetailsAsync(Id);
            if (refresh.Success) _trip = refresh.Trip;
        }
        else
        {
            _saveError = result.Error;
        }

        _saving = false;
    }

    private static string ImageDataUrl(string base64)
    {
        var mime = base64.StartsWith("/9j/")   ? "jpeg"
                 : base64.StartsWith("iVBOR")  ? "png"
                 : base64.StartsWith("R0lGOD") ? "gif"
                 : "jpeg";
        return $"data:image/{mime};base64,{base64}";
    }

    private class EditModel
    {
        [Required] public string  From         { get; set; } = string.Empty;
        [Required] public string  To           { get; set; } = string.Empty;
        [Range(1, 50)] public int TotalSeats   { get; set; } = 1;
        [Range(0, 99999)] public decimal PricePerSeat { get; set; }
        public DateTime  DepartureTime { get; set; }
        public string?   Note         { get; set; }
        public string?   NumberPlate  { get; set; }
    }
}
