@page "/trips/{Id:guid}"
@rendermode InteractiveServer
@attribute [Authorize(Policy = "DriverOnly")]
@using GoCheaper.Web.Services
@using System.ComponentModel.DataAnnotations
@inject TripsApiClient TripsClient
@inject BookingApiClient BookingClient
@inject UserSession UserSession
@inject NavigationManager Nav

<PageTitle>Trip Details - GoCheaper</PageTitle>

<div class="container py-4" style="max-width:800px">
    <a href="/my-trips" class="btn btn-outline-secondary btn-sm mb-3">← My Trips</a>

    @if (_loading)
    {
        <div class="spinner-border text-primary" role="status"></div>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger">@_error</div>
    }
    @if (_trip is not null)
    {
        var isOwner = UserSession.UserId.HasValue && UserSession.UserId.Value == _trip.DriverId;

        @if (isOwner && _editing)
        {
            <!-- ── Driver: edit form ── -->
            <div class="card shadow-sm">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span class="fw-semibold">Edit Trip</span>
                    <button class="btn btn-sm btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
                </div>
                <div class="card-body">
                    @if (_bookedSeats > 0)
                    {
                        <div class="alert alert-info mb-3">
                            <strong>This trip has @_bookedSeats booking(s).</strong> Only the note, pickup points, payment method and number plate can be edited.
                        </div>
                    }
                    <EditForm Model="_edit" OnValidSubmit="SaveEditAsync">
                        <DataAnnotationsValidator />

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">From</label>
                                <InputText class="form-control" @bind-Value="_edit.From" disabled="@(_bookedSeats > 0)" />
                                <ValidationMessage For="() => _edit.From" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">To</label>
                                <InputText class="form-control" @bind-Value="_edit.To" disabled="@(_bookedSeats > 0)" />
                                <ValidationMessage For="() => _edit.To" />
                            </div>
                        </div>

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Total Seats</label>
                                <InputNumber class="form-control" @bind-Value="_edit.TotalSeats" disabled="@(_bookedSeats > 0)" />
                                <ValidationMessage For="() => _edit.TotalSeats" />
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-semibold">Price per Seat (DKK)</label>
                                <InputNumber class="form-control" @bind-Value="_edit.PricePerSeat" disabled="@(_bookedSeats > 0)" />
                                <ValidationMessage For="() => _edit.PricePerSeat" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Departure Date &amp; Time</label>
                            <InputDate Type="InputDateType.DateTimeLocal" class="form-control" @bind-Value="_edit.DepartureTime" disabled="@(_bookedSeats > 0)" />
                            <ValidationMessage For="() => _edit.DepartureTime" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Number Plate</label>
                            <InputText class="form-control" @bind-Value="_edit.NumberPlate" />
                            <ValidationMessage For="() => _edit.NumberPlate" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Note</label>
                            <InputTextArea class="form-control" @bind-Value="_edit.Note" rows="3" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Currency</label>
                            <InputSelect class="form-select" @bind-Value="_edit.Currency" disabled="@(_bookedSeats > 0)">
                                <option value="DKK">DKK – Danish Krone</option>
                                <option value="NOK">NOK – Norwegian Krone</option>
                                <option value="SEK">SEK – Swedish Krona</option>
                            </InputSelect>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Payment Method</label>
                            <InputText class="form-control" @bind-Value="_edit.PaymentMethod"
                                       placeholder="e.g. Cash, MobilePay (DK), Vipps (NO), Swish (SE)" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-semibold">Pickup Points</label>
                            @for (var i = 0; i < _editPickupPoints.Count; i++)
                            {
                                var index = i;
                                <div class="mb-2">
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <span class="badge bg-secondary">@(index + 1)</span>
                                        <button type="button" class="btn btn-outline-danger btn-sm ms-auto"
                                                @onclick="() => _editPickupPoints.RemoveAt(index)">✕ Remove</button>
                                    </div>
                                    <input class="form-control" value="@_editPickupPoints[index]"
                                           @oninput="e => _editPickupPoints[index] = e.Value?.ToString() ?? string.Empty"
                                           placeholder="Address or landmark" />
                                </div>
                            }
                            <button type="button" class="btn btn-outline-secondary btn-sm"
                                    @onclick="() => _editPickupPoints.Add(string.Empty)">+ Add Pickup Point</button>
                            @if (_editPickupPointsError is not null)
                            {
                                <div class="text-danger small mt-1">@_editPickupPointsError</div>
                            }
                        </div>

                        @if (_saveError is not null)
                        {
                            <div class="alert alert-danger">@_saveError</div>
                        }

                        <div class="d-flex gap-2 mt-4">
                            <button type="submit" class="btn btn-primary" disabled="@_saving">
                                @(_saving ? "Saving..." : "Save Changes")
                            </button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        }
        else
        {
            <!-- ── Read-only view (driver + passenger) ── -->
            <div class="card shadow-sm">
                <div class="card-header py-3">
                    <div class="d-flex flex-wrap justify-content-between align-items-start gap-2">
                        <div>
                            <h2 class="h5 mb-1 fw-semibold">@_trip.From &rarr; @_trip.To</h2>
                            <span class="text-muted small">Driver: <strong>@(_trip.DriverFullName == "Unknown Driver" && isOwner ? (UserSession.FullName ?? _trip.DriverFullName) : _trip.DriverFullName)</strong></span>
                        </div>
                        <div class="d-flex flex-wrap align-items-center gap-2">
                            @if (!string.IsNullOrEmpty(_trip.CarPictureBase64))
                            {
                                <div>
                                    <img src="@ImageDataUrl(_trip.CarPictureBase64)"
                                         alt="@(_trip.NumberPlate ?? "Car")"
                                         style="height:56px;object-fit:cover;border-radius:6px;" />
                                    @if (_trip.NumberPlate is not null)
                                    {
                                        <div class="text-center"><small class="text-muted">@_trip.NumberPlate</small></div>
                                    }
                                </div>
                            }
                            @if (isOwner)
                            {
                                <div class="d-flex flex-wrap gap-2">
                                    <button class="btn btn-sm btn-outline-primary" @onclick="StartEdit">Edit Trip</button>
                                    <button class="btn btn-sm btn-outline-danger" @onclick="() => _confirmDelete = true">Delete Trip</button>
                                </div>
                            }
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <dl class="row mb-0">
                        <dt class="col-sm-4">Departure</dt>
                        <dd class="col-sm-8">@(_trip.DepartureTime?.ToString("dd MMM yyyy HH:mm") ?? "—")</dd>

                        <dt class="col-sm-4">Seats</dt>
                        <dd class="col-sm-8">@_bookedSeats booked / @_trip.TotalSeats total &nbsp;<span class="text-muted small">(@(_trip.TotalSeats - _bookedSeats) available)</span></dd>

                        <dt class="col-sm-4">Price per Seat</dt>
                        <dd class="col-sm-8">@_trip.PricePerSeat.ToString("N2") @(_trip.Currency ?? "DKK")</dd>

                        @if (_trip.NumberPlate is not null && string.IsNullOrEmpty(_trip.CarPictureBase64))
                        {
                            <dt class="col-sm-4">Number Plate</dt>
                            <dd class="col-sm-8">@_trip.NumberPlate</dd>
                        }

                        @if (!string.IsNullOrWhiteSpace(_trip.Note))
                        {
                            <dt class="col-sm-4">Note</dt>
                            <dd class="col-sm-8">@_trip.Note</dd>
                        }

                        @if (!string.IsNullOrWhiteSpace(_trip.PaymentMethod))
                        {
                            <dt class="col-sm-4">Payment Method</dt>
                            <dd class="col-sm-8">@_trip.PaymentMethod</dd>
                        }

                        @if (_trip.PickupPoints is { Count: > 0 })
                        {
                            <dt class="col-sm-4">Pickup Points</dt>
                            <dd class="col-sm-8">
                                <ol class="mb-0 ps-3">
                                    @foreach (var point in _trip.PickupPoints)
                                    {
                                        <li>@point</li>
                                    }
                                </ol>
                            </dd>
                        }
                    </dl>
                </div>
            </div>
        }
    }
</div>

<ConfirmModal Show="_confirmDelete"
              Title="Delete Trip"
              ConfirmLabel="@(_deleting ? "Deleting..." : "OK")"
              CancelLabel="Cancel"
              ConfirmDisabled="_deleting"
              OnConfirm="ConfirmDeleteAsync"
              OnCancel="CancelDelete">
    <p class="text-muted mb-3">Permanently deletes this trip. Passengers with bookings will be notified by email.</p>
    <label class="form-label small fw-semibold">Reason for deletion (optional)</label>
    <textarea class="form-control" rows="2"
              placeholder="Sent to passengers if provided"
              @bind="_deleteReason"></textarea>
    @if (_deleteError is not null)
    {
        <div class="text-danger small mt-2">@_deleteError</div>
    }
</ConfirmModal>

@code {
    [Parameter] public Guid Id { get; set; }

    private TripDetailsResponse? _trip;
    private int     _bookedSeats;
    private bool    _loading = true;
    private string? _error;

    // delete
    private bool    _confirmDelete;
    private bool    _deleting;
    private string? _deleteError;
    private string  _deleteReason = string.Empty;


    // owner editing
    private bool _editing;
    private bool _saving;
    private string? _saveError;
    private string? _editPickupPointsError;
    private readonly EditModel _edit = new();
    private readonly List<string> _editPickupPoints = [];

    protected override async Task OnInitializedAsync()
    {
        var result = await TripsClient.GetTripDetailsAsync(Id);
        if (result.Success)
        {
            _trip = result.Trip;
            var counts = await BookingClient.GetBookedSeatsAsync([Id]);
            _bookedSeats = counts.GetValueOrDefault(Id, 0);
        }
        else
        {
            _error = result.Error;
        }
        _loading = false;
    }

    private async Task ConfirmDeleteAsync()
    {
        _deleting = true;
        _deleteError = null;
        var result = await TripsClient.DeleteTripAsync(Id, _deleteReason);
        if (result.Success)
            Nav.NavigateTo("/my-trips");
        else
        {
            _deleteError = result.Error;
            _confirmDelete = false;
        }
        _deleting = false;
    }

    private void CancelDelete()
    {
        _confirmDelete = false;
        _deleteReason  = string.Empty;
    }

    private void StartEdit()
    {
        if (_trip is null) return;
        _edit.From          = _trip.From;
        _edit.To            = _trip.To;
        _edit.TotalSeats    = _trip.TotalSeats;
        _edit.PricePerSeat  = _trip.PricePerSeat;
        _edit.DepartureTime = _trip.DepartureTime;
        _edit.Note          = _trip.Note;
        _edit.PaymentMethod = _trip.PaymentMethod;
        _edit.Currency      = _trip.Currency ?? "DKK";
        _edit.NumberPlate   = _trip.NumberPlate;
        _editPickupPoints.Clear();
        _editPickupPoints.AddRange(_trip.PickupPoints);
        _saveError = null;
        _editing = true;
    }

    private void CancelEdit()
    {
        _editing = false;
        _saveError = null;
    }

    private async Task SaveEditAsync()
    {
        _saving = true;
        _saveError = null;

        var validPickupPoints = _editPickupPoints.Where(p => !string.IsNullOrWhiteSpace(p)).ToList();
        if (validPickupPoints.Count == 0)
        {
            _editPickupPointsError = "At least one pickup point is required.";
            _saving = false;
            return;
        }
        _editPickupPointsError = null;

        var locked = _bookedSeats > 0;
        var result = await TripsClient.UpdateTripAsync(Id, new
        {
            From          = locked ? null : _edit.From,
            To            = locked ? null : _edit.To,
            TotalSeats    = locked ? (int?)null    : (int?)_edit.TotalSeats,
            PricePerSeat  = locked ? (decimal?)null : (decimal?)_edit.PricePerSeat,
            DepartureTime = locked ? (DateTime?)null : _edit.DepartureTime,
            _edit.Note,
            _edit.PaymentMethod,
            Currency      = locked ? null : _edit.Currency,
            _edit.NumberPlate,
            PickupPoints  = validPickupPoints
        });

        if (result.Success)
        {
            _editing = false;
            var refresh = await TripsClient.GetTripDetailsAsync(Id);
            if (refresh.Success) _trip = refresh.Trip;
            var counts = await BookingClient.GetBookedSeatsAsync([Id]);
            _bookedSeats = counts.GetValueOrDefault(Id, 0);
        }
        else
        {
            _saveError = result.Error;
        }

        _saving = false;
    }

    private static string ImageDataUrl(string base64)
    {
        var mime = base64.StartsWith("/9j/")   ? "jpeg"
                 : base64.StartsWith("iVBOR")  ? "png"
                 : base64.StartsWith("R0lGOD") ? "gif"
                 : "jpeg";
        return $"data:image/{mime};base64,{base64}";
    }

    private class EditModel
    {
        [Required] public string From { get; set; } = string.Empty;
        [Required] public string To   { get; set; } = string.Empty;
        [Range(1, 50)] public int TotalSeats { get; set; } = 1;
        [Range(1, 99999, ErrorMessage = "Price per seat must be at least 1 DKK.")] public decimal PricePerSeat { get; set; }
        [Required(ErrorMessage = "Departure date and time is required.")] public DateTime? DepartureTime { get; set; }
        [Required(ErrorMessage = "Number plate is required.")] public string? NumberPlate { get; set; }
        public string? Note          { get; set; }
        public string? PaymentMethod { get; set; }
        public string  Currency      { get; set; } = "DKK";
    }
}
