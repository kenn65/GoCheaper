@page "/passenger/trips/{Id:guid}"
@rendermode InteractiveServer
@attribute [Authorize]
@using GoCheaper.Web.Services
@inject BookingApiClient BookingClient
@inject UserSession UserSession
@inject NavigationManager Nav

<PageTitle>Trip Details - GoCheaper</PageTitle>

<div class="container py-4" style="max-width: 680px;">
    <a href="/browse-trips" class="btn btn-sm btn-outline-secondary mb-3">&#8592; Browse Trips</a>

    @if (_loading)
    {
        <div class="text-center py-5">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (_error is not null)
    {
        <div class="alert alert-danger">@_error</div>
    }
    else if (_trip is not null)
    {
        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white py-3 d-flex justify-content-between align-items-center">
                <div>
                    <div class="d-flex align-items-center gap-2 flex-wrap">
                        <h5 class="mb-0">@_trip.From &rarr; @_trip.To</h5>
                        <span class="badge @TripStatus.BadgeClass(_trip.DepartureTime)">@TripStatus.Compute(_trip.DepartureTime)</span>
                    </div>
                    <small class="text-white opacity-75">
                        Driver: <a href="/driver/@_trip.DriverId" class="text-white">@_trip.DriverFullName</a>
                    </small>
                </div>
            </div>
            <div class="card-body">
                <dl class="row mb-0">
                    <dt class="col-sm-4">Departure</dt>
                    <dd class="col-sm-8">@(_trip.DepartureTime?.ToString("dd MMM yyyy HH:mm") ?? "—")</dd>

                    <dt class="col-sm-4">Available Seats</dt>
                    <dd class="col-sm-8">@_trip.AvailableSeats of @_trip.TotalSeats</dd>

                    <dt class="col-sm-4">Price per Seat (@_trip.Currency)</dt>
                    <dd class="col-sm-8">@_trip.PricePerSeat.ToString("N2") @_trip.Currency</dd>

                    @if (!string.IsNullOrWhiteSpace(_trip.NumberPlate))
                    {
                        <dt class="col-sm-4">Number Plate</dt>
                        <dd class="col-sm-8">@_trip.NumberPlate</dd>
                    }

                    @if (!string.IsNullOrWhiteSpace(_trip.PaymentMethod))
                    {
                        <dt class="col-sm-4">Payment Method</dt>
                        <dd class="col-sm-8">@_trip.PaymentMethod</dd>
                    }

                    @if (!string.IsNullOrWhiteSpace(_trip.Note))
                    {
                        <dt class="col-sm-4">Note</dt>
                        <dd class="col-sm-8">@_trip.Note</dd>
                    }

                    @if (_trip.PickupPoints.Count > 0)
                    {
                        <dt class="col-sm-4"><strong>Pickup Points</strong></dt>
                        <dd class="col-sm-8">
                            <ol class="mb-0 ps-3">
                                @foreach (var pt in _trip.PickupPoints)
                                {
                                    <li>@pt</li>
                                }
                            </ol>
                        </dd>
                    }
                </dl>
            </div>

            <div class="card-footer" id="book">
                @if (_bookingStatus is not null)
                {
                    <div class="alert alert-success mb-2">
                        You have booked <strong>@_bookingStatus.SeatsCount seat(s)</strong> on this trip.
                    </div>
                    @if (_cancelError is not null)
                    {
                        <div class="alert alert-danger">@_cancelError</div>
                    }
                    <button class="btn btn-outline-danger btn-sm" @onclick="() => _confirmCancel = true">
                        Cancel Booking
                    </button>
                }
                else if (_trip.AvailableSeats > 0)
                {
                    @if (_bookError is not null)
                    {
                        <div class="alert alert-danger mb-2">@_bookError</div>
                    }
                    <div class="d-flex flex-column gap-3 py-2">
                        <div class="d-flex align-items-center gap-3">
                            <label class="form-label mb-0 fw-semibold">Number of seats</label>
                            <input type="number" class="form-control" style="width:100px"
                                   min="1" max="@_trip.AvailableSeats" @bind="_seatsToBook" />
                        </div>
                        <button class="btn btn-primary btn-lg w-100 fw-bold py-3"
                                style="font-size:1.2rem;letter-spacing:.3px;border-radius:10px"
                                @onclick="BookAsync" disabled="@_actionBusy">
                            @if (_actionBusy)
                            {
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                <span>Booking&hellip;</span>
                            }
                            else
                            {
                                <span>Book This Trip</span>
                            }
                        </button>
                    </div>
                }
                else
                {
                    <span class="text-muted small">This trip is fully booked.</span>
                }
            </div>
        </div>
    }
</div>

<NotificationModal Show="_showBookingModal"
                   Title="Booking Confirmed"
                   Message="Your seat is reserved. A booking confirmation has been emailed to you."
                   OnClose="GoToMyBookings" />

<NotificationModal Show="_showCancelModal"
                   Title="Booking Cancelled"
                   Message="@($"Your booking has been cancelled. Redirecting to Browse Trips in {_cancelCountdown}…")"
                   OnClose="() => Nav.NavigateTo("/browse-trips")" />

<ConfirmModal Show="_confirmCancel"
              Title="Cancel Booking"
              Message="Are you sure you want to cancel your booking? The seats will be freed for other passengers."
              ConfirmLabel="@(_actionBusy ? "Cancelling..." : "OK")"
              CancelLabel="Cancel"
              ConfirmDisabled="_actionBusy"
              OnConfirm="CancelBookingAsync"
              OnCancel="() => _confirmCancel = false" />

@code {
    [Parameter] public Guid Id { get; set; }

    private BrowseTripDetail?      _trip;
    private BookingStatusResponse? _bookingStatus;
    private bool    _loading          = true;
    private string? _error;
    private string? _bookError;
    private string? _cancelError;
    private bool    _actionBusy;
    private int     _seatsToBook      = 1;
    private bool    _showBookingModal;
    private bool    _showCancelModal;
    private int     _cancelCountdown  = 3;
    private bool    _confirmCancel;

    private void GoToMyBookings() => Nav.NavigateTo("/my-booked-trips");

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        await LoadAsync();
        StateHasChanged();
    }

    private async Task LoadAsync()
    {
        var detailResult = await BookingClient.GetTripDetailAsync(Id);
        if (!detailResult.Success) { _error = detailResult.Error; _loading = false; return; }
        _trip = detailResult.Trip;

        if (UserSession.IsLoggedIn)
        {
            var statusResult = await BookingClient.GetMyBookingAsync(Id);
            _bookingStatus = statusResult.Found ? statusResult.Booking : null;
        }

        _loading = false;
    }

    private async Task BookAsync()
    {
        _actionBusy = true;
        _bookError  = null;
        var result = await BookingClient.BookTripAsync(Id, _seatsToBook);
        if (result.Success)
        {
            await LoadAsync();
            _showBookingModal = true;
        }
        else
        {
            _bookError = result.Error;
        }
        _actionBusy = false;
    }

    private async Task CancelBookingAsync()
    {
        _actionBusy  = true;
        _cancelError = null;
        var result = await BookingClient.CancelBookingAsync(Id);
        if (result.Success)
        {
            _confirmCancel   = false;
            _cancelCountdown = 3;
            _showCancelModal = true;
            StateHasChanged();
            while (_cancelCountdown > 0)
            {
                await Task.Delay(1000);
                _cancelCountdown--;
                StateHasChanged();
            }
            Nav.NavigateTo("/browse-trips");
        }
        else
        {
            _confirmCancel = false;
            _cancelError   = result.Error;
        }
        _actionBusy = false;
    }
}
