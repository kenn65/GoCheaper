@inherits LayoutComponentBase

<NavMenu />

<div class="container-fluid py-4" style="flex:1">
    @Body
</div>

<footer class="border-top mt-4 py-3 text-center text-muted small">
    <div class="container">
        <a href="/privacy-policy" class="me-3">Privacy Policy</a>
        <a href="https://github.com/kenn65/GoCheaper" target="_blank" rel="noopener" class="me-3">Open Source</a>
        <span>&copy; @DateTime.Now.Year GoCheaper &mdash; non-profit, free to use</span>
    </div>
</footer>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">&#x2715;</span>
</div>
