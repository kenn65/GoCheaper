@using GoCheaper.Web.Services
@inject UserSession UserSession
@inject AuthCookieService AuthCookies
@inject NavigationManager Nav
@implements IDisposable

<nav class="navbar navbar-expand-sm navbar-dark bg-primary px-3 shadow-sm">
    <a class="navbar-brand fw-bold" href="/">GoCheaper</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
            data-bs-target="#navContent" aria-controls="navContent"
            aria-expanded="false" aria-label="Toggle navigation">
        <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="navContent">
        <ul class="navbar-nav me-auto">
            @if (UserSession.IsLoggedIn)
            {
                <li class="nav-item">
                    <NavLink class="nav-link" href="/my-profile" Match="NavLinkMatch.Prefix">
                        My Profile
                    </NavLink>
                </li>
                @if (UserSession.IsDriver)
                {
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/my-trips" Match="NavLinkMatch.Prefix">
                            My Trips
                        </NavLink>
                    </li>
                }
                @if (UserSession.IsPassenger)
                {
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/browse-trips" Match="NavLinkMatch.Prefix">
                            Browse Trips
                        </NavLink>
                    </li>
                    <li class="nav-item">
                        <NavLink class="nav-link" href="/my-booked-trips" Match="NavLinkMatch.Prefix">
                            My Booked Trips
                        </NavLink>
                    </li>
                }
            }
        </ul>

        <ul class="navbar-nav ms-auto align-items-center gap-2">
            @if (UserSession.IsLoggedIn)
            {
                <li class="nav-item">
                    <span class="text-white opacity-75 small">
                        @(string.IsNullOrWhiteSpace(UserSession.FullName) ? UserSession.Email : UserSession.FullName)
                    </span>
                </li>
                <li class="nav-item">
                    <button class="btn btn-outline-light btn-sm" @onclick="HandleSignOut">
                        Sign Out
                    </button>
                </li>
            }
            else
            {
                <li class="nav-item">
                    <NavLink class="btn btn-outline-light btn-sm" href="/login" Match="NavLinkMatch.Prefix">
                        Sign In
                    </NavLink>
                </li>
            }
        </ul>
    </div>
</nav>

@code {
    protected override void OnInitialized()
        => UserSession.OnChange += OnSessionChanged;

    private void OnSessionChanged()
        => InvokeAsync(StateHasChanged);

    private async Task HandleSignOut()
    {
        await AuthCookies.SignOutAsync();
        Nav.NavigateTo("/", forceLoad: true);
    }

    public void Dispose()
        => UserSession.OnChange -= OnSessionChanged;
}
