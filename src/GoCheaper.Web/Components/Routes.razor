@using GoCheaper.Web.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject UserSession UserSession
@inject NavigationManager Nav
@implements IDisposable

<Router AppAssembly="typeof(Program).Assembly" NotFoundPage="typeof(Pages.NotFound)">
    <Found Context="routeData">
        <AuthorizeRouteView RouteData="routeData" DefaultLayout="typeof(Layout.MainLayout)">
            <NotAuthorized>
                <RedirectToLogin />
            </NotAuthorized>
        </AuthorizeRouteView>
        <FocusOnNavigate RouteData="routeData" Selector="h1" />
    </Found>
</Router>

@code {
    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    protected override async Task OnInitializedAsync()
    {
        Nav.LocationChanged += OnLocationChanged;

        if (AuthState is not null)
        {
            var state = await AuthState;
            UserSession.LoadFromClaims(state.User);
            RedirectIfIncomplete(Nav.Uri);
        }
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
        => RedirectIfIncomplete(e.Location);

    private void RedirectIfIncomplete(string uri)
    {
        if (!UserSession.IsLoggedIn || UserSession.IsProfileComplete) return;
        var path = new Uri(uri).AbsolutePath.TrimStart('/');
        if (path != "complete-profile")
            Nav.NavigateTo("/complete-profile");
    }

    public void Dispose()
        => Nav.LocationChanged -= OnLocationChanged;
}
